# Perfiai Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun: cp .env.example .env

# ========== Backend (Node) ==========
PORT=3001
JWT_SECRET=your-secret-key-change-in-production

# Yerelde NODE_ENV=production yapma: e-posta düşmezse API yanıtında dev kodu gösterilmez.
# Boş bırak veya: NODE_ENV=development
#
# Kayıtta frontend `locale: "tr" | "en"` gönderir; doğrulama / giriş kodu e-postası bu dile göre gider.

# E-posta: giriş kodu + kayıt sonrası doğrulama linki (nodemailer)
# Backend perfiai/.env ve perfiai/backend/.env dosyalarını başlarken okur (dotenv).
# SMTP_HOST / SMTP_USER / SMTP_PASS yoksa e-posta GİTMEZ; kod/URL backend konsoluna yazılır.
SITE_URL=http://localhost:3000

# --- Gmail ---
# 1) Google Hesabı → Güvenlik → 2 Adımlı Doğrulama açık olmalı
# 2) "Uygulama şifreleri" ile 16 haneli şifre oluştur
# 3) SMTP_PASS = bu şifre (normal Gmail şifren değil; boşluklu yazılabilir)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Port 465 kullanıyorsan: SMTP_SECURE=1
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# İsteğe bağlı gönderen başlığı (yoksa SMTP_USER)
# SMTP_FROM=Perfiai <your-email@gmail.com>

# SMTP_DEBUG=1                    # konsolda ham SMTP logu
# SMTP_REQUIRE_TLS=0              # MailHog gibi yerel test için
#
# "self-signed certificate in certificate chain" / TLS hatası: genelde antivirüs veya kurumsal proxy.
# Sadece yerel deneme için (üretimde kullanmayın):
# SMTP_TLS_REJECT_UNAUTHORIZED=0

# Outlook: smtp-mail.outlook.com:587
# Resend vb.: sağlayıcının SMTP sayfasına bakın

# MongoDB Atlas (opsiyonel - yoksa JSON kullanılır)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/perfiai?retryWrites=true&w=majority

# ========== Embedding Modu ==========
# Seçenek 1: SentenceTransformers (lokal Python servisi, ücretsiz)
# embedding_server.py'yi port 8001'de çalıştırın
USE_ST_EMBEDDING=1
SENTENCE_EMBEDDING_URL=http://localhost:8001/embed

# Seçenek 2: OpenAI Embedding (ücretli)
# USE_ST_EMBEDDING kullanmıyorsanız OPENAI_API_KEY gerekir
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ========== LLM (Ollama) - Opsiyonel ==========
# AI arama sonuçlarındaki "reason" açıklamaları için LLM kullan
# 0 veya boş = kural tabanlı açıklama (varsayılan)
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
